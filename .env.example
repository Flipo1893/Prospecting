# ─────────────────────────────────────────────────────────────
# Supabase (Postgres + Auth)
# Zu finden unter: Supabase Dashboard > Project Settings > API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────
# Zefix API (Schweizer Handelsregister, www.zefix.ch)
# Öffentliche PublicREST-API von zefix.admin.ch.
# Registrierung / Bezug eines Access Tokens:
#   https://www.zefix.admin.ch/de/search/entity/welcome -> "ZEFIX PublicREST"
#   bzw. https://www.zefix.ch/ZefixPublicREST/ (Swagger-Dokumentation)
# Ohne diese Variablen läuft die App automatisch im Mock-Modus
# mit Beispieldaten (siehe README, Abschnitt "Zefix-Anbindung").
# ─────────────────────────────────────────────────────────────
ZEFIX_API_BASE_URL=https://www.zefix.admin.ch/ZefixPublicREST/api/v1
ZEFIX_API_KEY=

# Auf "true" setzen, um erzwungen im Mock-Modus zu arbeiten,
# auch wenn ZEFIX_API_KEY gesetzt ist (praktisch für lokale Demos).
ZEFIX_FORCE_MOCK=false

# ─────────────────────────────────────────────────────────────
# Stufe 2 (Vorbereitung): Google Places API für Anreicherung
# (Website, Telefon, Bewertungen). Noch nicht in Stufe 1 genutzt.
# ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
